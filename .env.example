# Copy this file to .env and fill in values for your environment.
# Local dev defaults (matching docker-compose.yml) are shown — no changes needed for local dev.

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=jdbc:postgresql://localhost:5432/framezero
DATABASE_USER=framezero
DATABASE_PASSWORD=framezero

# ─── JWT (required in production; auto-supplied in dev mode) ─────────────────
# JWT_SECRET=change-me-in-production
# JWT_ISSUER=framezero
# JWT_AUDIENCE=framezero-api
# JWT_REALM=framezero

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated browser origins allowed to call the API. Entries may include
# a scheme (https assumed when omitted). Dev mode allows any origin when unset;
# production rejects all cross-origin browser requests when unset (mobile
# clients are unaffected — they send no Origin header).
# CORS_ALLOWED_ORIGINS=https://app.framezero.com,https://staging.framezero.com
