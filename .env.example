# Copy this file to .env and fill in values for your environment.
# Local dev defaults (matching docker-compose.yml) are shown — no changes needed for local dev.

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=jdbc:postgresql://localhost:5432/framezero
DATABASE_USER=framezero
DATABASE_PASSWORD=framezero

# ─── JWT (required in production; auto-supplied in dev mode) ─────────────────
# JWT_SECRET=change-me-in-production
# JWT_ISSUER=framezero
# JWT_AUDIENCE=framezero-api
# JWT_REALM=framezero
